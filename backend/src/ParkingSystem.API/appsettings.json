{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "JwtSettings": {
    "Issuer": "ParkingSystemAPI",
    "Audience": "ParkingSystemClients",
    "Secret": "REPLACE_WITH_USER_SECRETS_OR_ENV_VAR_MIN_32_CHARS",
    "AccessTokenLifetimeMinutes": 60,
    "RefreshTokenLifetimeDays": 7
  },
  "AISettings": {
    "RecommendationTimeoutMs": 2000
  }
}
